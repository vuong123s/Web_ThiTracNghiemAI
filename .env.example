# QuizFlow Environment Variables
# Copy this file to .env and fill in your actual values

# Secret key for session management (generate a random string)
SECRET_KEY=your-secret-key-here

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=quizflow

# ============ AI Providers - NineGPT ============

# OpenAI API Key (https://platform.openai.com/api-keys)
# Format: sk-proj-...
# Lưu ý: Kiểm tra quota tại https://platform.openai.com/account/billing/overview
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# OpenAI Model (optional, default: gpt-4o-mini)
# Tùy chọn: gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
# Format: AIza...
GEMINI_API_KEY=AIza-your-gemini-api-key-here

# Gemini Model (optional, default: gemini-2.0-flash-exp)
# Nếu gặp lỗi 404 "model not found", thử các model khác:
# - gemini-2.0-flash-exp (mới nhất, nên dùng)
# - gemini-1.5-pro (ổn định)
# - gemini-1.5-flash (tiết kiệm)
# - gemini-pro (cũ, tương thích v1beta)
GEMINI_MODEL=gemini-2.0-flash-exp

# Gemini API Version (optional, default: v1)
# v1: Hỗ trợ các model mới (gemini-2.0-flash-exp, gemini-1.5-pro, etc.)
# v1beta: Chỉ hỗ trợ gemini-pro, gemini-pro-vision (cũ)
GEMINI_API_VERSION=v1

# ============ Retry & Fallback Configuration ============

# Số lần thử lại khi API fail (default: 3)
# Chỉ áp dụng cho lỗi tạm thời (rate limit, timeout, server error)
# Lỗi vĩnh viễn (404, 401, insufficient_quota) không được retry
AI_MAX_RETRIES=3

# Độ trễ giữa các lần thử (giây, default: 2)
AI_RETRY_DELAY=2

# Exponential backoff multiplier (default: 2.0)
# Mỗi lần retry, độ trễ = delay * multiplier ^ attempt
# Ví dụ: 2s, 4s, 8s, 16s với multiplier=2.0
AI_RETRY_BACKOFF=2.0

# Bật/tắt fallback provider (default: true)
# Khi 1 provider fail, tự động thử provider khác
# Ví dụ: OpenAI fail → thử Gemini
AI_ENABLE_FALLBACK=true

# Provider fallback (default: gemini)
# Khi PRIMARY provider (OpenAI) fail, fallback sang provider này
# Tùy chọn: gemini (nên dùng), openai
AI_FALLBACK_PROVIDER=gemini

